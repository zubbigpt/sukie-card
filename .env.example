# Copia este archivo como .env para desarrollo local

# Railway te da esta variable automáticamente cuando añades PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sukiecard

# URL pública de tu app en Railway (ej: https://sukie-card.up.railway.app)
BASE_URL=https://TU-APP.up.railway.app

# PIN para que Sukie acceda al panel admin y añada sellos (cámbialo)
ADMIN_PIN=1234

# Clave secreta para que Make.com llame a la API (cámbiala)
API_KEY=sukie-secret-key-cambia-esto

# Cuántos sellos = 1 premio (default: 10)
STAMPS_PER_REWARD=10
